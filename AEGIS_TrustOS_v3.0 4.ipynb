   "source": [
    "import ipywidgets as widgets\n",
    "\n",
    "heartbeat_slider = widgets.FloatSlider(value=0.5, min=0.0, max=1.0, step=0.01, description=\'National Pulse:\')\n",
    "output_beast = widgets.Output()\n",
    "\n",
    "def update_beast_mode(change):\n",
    "    with output_beast:\n",
    "        clear_output(wait=True)\n",
    "        pulse = heartbeat_slider.value\n",
    "        \n",
    "        # If pulse is low (Injustice/Danger), sensitivity spikes\n",
    "        sensitivity = 1.0 / (pulse + 0.1)\n",
    "        \n",
    "        color = \"#ff0000\" if pulse < 0.3 else \"#ffffff\"\n",
    "        status = \"🔴 CRITICAL RESONANCE: DEFENSES MAXIMIZED\" if pulse < 0.3 else \"⚪ STABLE RESONANCE\"\n",
    "        \n",
    "        display(HTML(f\"\"\"\n",
    "            <div style=\"background:#000; border:10px solid {color}; border-radius:50px; padding:60px; text-align:center;\">\n",
    "                <h1 style=\"color:{color}; letter-spacing:10px; animation:glitch 0.5s infinite;\">{status}</h1>\n",
    "                <p style=\"color:#fff; font-size:24px;\"><b>Sovereign Sensitivity:</b> {sensitivity:.2f}x</p>\n",
    "                <div style=\"width:100%; height:100px; background:#111; border-radius:20px; margin-top:30px; overflow:hidden;\">\n",
    "                    <div style=\"width:{pulse*100}%; height:100%; background:{color}; box-shadow:0 0 50px {color};\"></div>\n",
    "                </div>\n",
    "            </div>\n",
    "        \"\"\"))\n",
    "\n",
    "heartbeat_slider.observe(update_beast_mode, names=\'value\')\n",
    "display(widgets.VBox([heartbeat_slider, output_beast]))\n",
    "update_beast_mode(None)"
   ]
